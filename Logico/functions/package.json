{
  "name": "logico-functions",
  "description": "Backend de LogiCo (Firebase Functions + PostgreSQL)",
  "version": "1.0.0",
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "helmet": "^7.2.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "private": true
}
