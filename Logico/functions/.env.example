# =====================================================
# LogiCo - variables de entorno para Firebase Functions
# Copia este archivo a `.env` y completa con valores reales.
# =====================================================

# Conexión a Cloud SQL / PostgreSQL
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=logico
PG_USER=logico_app
PG_PASSWORD=changeme

# Si despliegas en Cloud Functions con Cloud SQL Auth Proxy,
# usa el socket en lugar de host/port:
# PG_HOST=/cloudsql/PROJECT:REGION:INSTANCE

# Pool
PG_MAX_POOL=10
PG_IDLE_MS=30000

# Firebase project (usado por firebase-admin si no auto-detecta)
GCLOUD_PROJECT=logico-app

# Auto-provisión de usuarios (seguro por defecto: DESHABILITADA).
# - Sin definir o cualquier valor != 'true'  -> solo usuarios ya dados de alta por un admin
#   en la tabla `usuarios` pueden usar la API (recomendado para producción).
# - 'true' -> un token Firebase válido sin fila crea automáticamente el usuario
#   (rol AUTH_AUTO_PROVISION_ROL). Úsalo solo en entornos de demo/desarrollo.
AUTH_AUTO_PROVISION=false
# Rol inicial al auto-aprovisionar (solo operadora | motorista)
AUTH_AUTO_PROVISION_ROL=operadora

# CORS: orígenes permitidos separados por coma. Si se omite, se usa la lista por
# defecto (dominios de Hosting del proyecto + localhost de desarrollo).
# CORS_ORIGINS=https://logico-20f73.web.app,https://logico-20f73.firebaseapp.com

# Entorno. En 'production' la API no expone detalles internos de error (Firebase/BD).
# Cloud Functions define NODE_ENV=production automáticamente en el despliegue.
# NODE_ENV=production
